# ===== Server =====
PORT=5000
NODE_ENV=development

# ===== Database =====
MONGODB_URI=mongodb://localhost:27017/blog_platform

# ===== JWT =====
JWT_SECRET=
JWT_REFRESH_SECRET=  # ← แยก secret สำหรับ refresh token

# ===== Email (SMTP) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_ENCRYPTION=tls
MAIL_FROM=noreply@example.com  # ← เพิ่ม sender email

# ===== Misc =====
SECRET_KEY=
# ===== Client =====
CLIENT_URL=https://yourdomain.com